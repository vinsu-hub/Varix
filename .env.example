# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cal.com booking embed — set to "username/event-slug" (e.g. "varix/discovery-call")
NEXT_PUBLIC_CALCOM_LINK=

# Webhook URL for inquiry form submissions (n8n or similar)
# Leave empty to skip webhook POST (Supabase insert still works)
INQUIRY_WEBHOOK_URL=
