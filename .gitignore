# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# unrelated project living alongside this one in the same directory
/hermes-agent/

# local Claude Code runtime state (per-user, not project source)
/.claude/
/.claude-flow/

# graphify-generated code knowledge graph (regenerate with `graphify update .`)
/graphify-out/

# internal agent workflow tooling/notes — not part of the website deliverable
/agent-vault/
